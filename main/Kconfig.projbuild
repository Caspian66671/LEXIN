config SLAVE_IDF_TARGET_ESP32C6
    bool
    default y if IDF_TARGET_ESP32P4

menu "LeXin Configuration"

    config LEXIN_WIFI_SSID
        string "WiFi SSID"
        default ""

    config LEXIN_WIFI_PASSWORD
        string "WiFi Password"
        default ""

    config LEXIN_WIFI_MAXIMUM_RETRY
        int "WiFi maximum retry"
        default 8

    config LEXIN_PROXY_BASE_URL
        string "Fast local proxy base URL"
        default "auto"

    config LEXIN_PROXY_PREFERRED_HOST
        string "Preferred fast proxy host IP"
        default "172.31.169.142"

    config LEXIN_PROXY_PORT
        int "Fast local proxy port"
        default 8787

endmenu
